{
    "name": "shopflow",
    "version": "1.0.0",
    "description": "Enterprise E-Commerce Platform built with Express, TypeScript, and Drizzle ORM",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio",
        "lint": "eslint .",
        "format": "prettier --write .",
        "lint:fix": "eslint . --fix",
        "test": "jest --runInBand",
        "prepare": "husky",
        "seed:admin": "tsx scripts/seed-admin.ts"
    },
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.4.3",
        "argon2": "^0.44.0",
        "bullmq": "^5.70.4",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "drizzle-orm": "^0.45.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "pg": "^8.20.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "swagger-ui-express": "^5.0.1",
        "xpress-toolkit": "^1.0.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.3.5",
        "@types/pg": "^8.18.0",
        "@types/supertest": "^7.2.0",
        "@types/swagger-ui-express": "^4.1.8",
        "drizzle-kit": "^0.31.9",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0"
    },
    "lint-staged": {
        "*.{ts,js}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,sql,yml,yaml}": [
            "prettier --write"
        ]
    }
}
