{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": ["ES2022"],
        "baseUrl": ".",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "noUncheckedIndexedAccess": true,
        "noEmitOnError": true,
        "types": ["node", "jest"],
        "paths": {
            "@modules/*": ["src/modules/*"],
            "@infrastructure/*": ["src/infrastructure/*"],
            "@config/*": ["src/config/*"],
            "@constants": ["src/constants"],
            "@errors": ["src/errors"],
            "@middlewares": ["src/middlewares"],
            "@routes": ["src/routes"],
            "@types": ["src/types"],
            "@utils": ["src/utils"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
