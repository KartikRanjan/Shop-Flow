{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": ["ES2022"],
        "baseUrl": ".",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "paths": {
            "@modules/*": ["src/modules/*"],
            "@infrastructure/*": ["src/infrastructure/*"],
            "@config/*": ["src/config/*"],
            "@constants/*": ["src/constants/*"],
            "@errors/*": ["src/errors/*"],
            "@middlewares/*": ["src/middlewares/*"],
            "@routes/*": ["src/routes/*"],
            "@types/*": ["src/types/*"],
            "@utils/*": ["src/utils/*"],
            "@constants": ["src/constants"],
            "@errors": ["src/errors"],
            "@middlewares": ["src/middlewares"],
            "@routes": ["src/routes"],
            "@types": ["src/types"],
            "@utils": ["src/utils"],
            "xpress-toolkit/swagger": ["node_modules/xpress-toolkit/dist/cjs/swagger/index.d.ts"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
